#include<iostream>
using namespace std;

class Solution {
public:
    void pattern8(int n) {
        for(int i=0; i<n; i++){
            // 1. Leading spaces
            for(int j=0; j<i; j++){
                cout << " ";
            }
            // 2. Stars
            //formula:2n-(2n-i+1)
            for(int j=0; j<2*n-(2*i+1); j++){
                cout << "*";
            }
            // 3. Removed trailing spaces loop completely
            cout << endl;
        }
    }
};

int main () {
    int t;
    cin >> t;
    Solution p8;
    for(int i=0; i<t; i++){
        int n;
        cin >> n;
        p8.pattern8(n);
    }
    return 0;
}
