#include <bits/stdc++.h>
using namespace std;

class patterns
{
public:
    void pattern9(int n)
    {
        for (int i = 1; i <= 2 * n - 1; i++)
        {
            int stars;

            if (i <= n)
                stars = i;
            else
                stars = 2 * n - i;

            for (int j = 1; j <= stars; j++)
            {
                cout << "*";
            }

            cout << endl;
        }
    }
};

int main()
{
    int n;
    cin >> n;

    patterns p9;
    p9.pattern9(n);

    return 0;
}
